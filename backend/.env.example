# ── Groq API ────────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── Model selection ──────────────────────────────────────────────────────
# llama-3.3-70b-versatile          → more accurate, best for strict JSON (default)
# llama-3.1-8b-instant             → faster, lower latency, good for short transcripts
# meta-llama/llama-4-scout-17b-16e-instruct  → latest generation, high capability
GROQ_MODEL=llama-3.3-70b-versatile
